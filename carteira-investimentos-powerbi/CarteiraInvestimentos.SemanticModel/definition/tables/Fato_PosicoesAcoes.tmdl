table Fato_PosicoesAcoes
	lineageTag: 674df80b-6869-4712-944d-398d867584d9

	measure 'Investido (Ações/FII)' = SUM(Fato_PosicoesAcoes[Investido])
		formatString: #,0.00
		lineageTag: 073903df-26a0-40f3-8e94-69885e6e0a53
		displayFolder: 2 Ações e FIIs

	measure 'Atualizado (Ações/FII)' = SUM(Fato_PosicoesAcoes[Atualizado])
