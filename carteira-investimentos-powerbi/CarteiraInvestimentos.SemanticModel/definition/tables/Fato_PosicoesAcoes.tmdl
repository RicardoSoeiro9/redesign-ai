		lineageTag: f191dd95-f1aa-40b3-b8dc-6e65a95d34f1
		displayFolder: 2 Ações e FIIs

	measure 'Rentabilidade (Ações/FII) %' = DIVIDE([L/P (Ações/FII)], [Investido (Ações/FII)])
		formatString: 0.00%
		lineageTag: 4c1b9f07-450e-4930-bbea-46d60e176f29
