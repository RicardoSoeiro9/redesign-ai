	partition Fato_PosicoesAcoes = m
		mode: import
		source =
				let
					Fonte = Csv.Document(File.Contents(PastaDados & "\fato_posicoes_acoes.csv"), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
					Cabecalho = Table.PromoteHeaders(Fonte, [PromoteAllScalars=true]),
					Tipado = Table.TransformColumnTypes(Cabecalho, {
						{"Ativo", type text},
						{"Segmento", type text},
						{"Quantidade", type number},
						{"PrecoMedio", type number},
						{"PrecoAtual", type number},
						{"Investido", type number},
						{"Atualizado", type number},
						{"LucroPrejuizo", type number},
						{"Variacao", type number},
						{"Dividendos", type number},
						{"YieldBruto", type number},
						{"YieldTotal", type number}
					})
				in
					Tipado


	annotation PBI_ResultType = Table
